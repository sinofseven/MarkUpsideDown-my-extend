{
  "$schema": "https://raw.githubusercontent.com/nicepkg/tauri-schema/main/schema/capability.json",
  "identifier": "default",
  "description": "Default capabilities for MarkUpsideDown",
  "windows": ["main", "main-*"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-confirm",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "$HOME/**" }]
    },
    "shell:default",
    "shell:allow-open",
    "store:default",
    "core:event:allow-listen",
    "fs:allow-watch"
  ]
}
