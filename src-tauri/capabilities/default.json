{
  "$schema": "https://raw.githubusercontent.com/nicepkg/tauri-schema/main/schema/capability.json",
  "identifier": "default",
  "description": "Default capabilities for MarkUpsideDown",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "shell:default"
  ]
}
